# ==============================================================================
# Quality Profiles
# ==============================================================================
profile.VERY_LOW=Very Low
profile.VERY_LOW.comment=Fastest possible preset for very weak GPUs. Disables heavy effects.
profile.LOW=Niski
profile.MED=Średni
profile.HIGH=Wysoki
profile.ULTRA=Ultra
profile.EXTREME=Extreme
profile.EXTREME.comment=Maksymalna jakość eksperymentalna. Dodaje SSAO/SAO kontaktowe ambient occlusion. POM pozostaje wyłączony dla stabilności.
profile.CUSTOM=Własny
profile.CUSTOM.comment=Niestandardowe ustawienia użytkownika.
profile.HIGH.comment=Wysoka jakość z dalszymi cieniami i jaśniejszym oświetleniem.
profile.LOW.comment=Najszybszy preset dla słabych GPU. Wyłącza ciężkie efekty.
profile.MED.comment=Zrównoważony preset z cieniami, chmurami, PBR i efektami atmosferycznymi.
profile.ULTRA.comment=Maksymalna jakość wizualna. POM pozostaje wyłączony dla stabilności.

screen.TRANSLATION_NOTICE=⚠ Tłumaczenia mogą zawierać błędy
screen.TRANSLATION_NOTICE.comment=Niektóre ciągi lokalizacji mogą być niedokładne. Jeśli coś wygląda dziwnie, porównaj z angielskim oryginałem.

