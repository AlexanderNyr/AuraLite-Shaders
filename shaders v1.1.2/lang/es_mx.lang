# ==============================================================================
# Extended shadow settings
# ==============================================================================
option.shadowDistance=Distancia de Sombras
option.shadowDistance.comment=Distancia máxima a la que se renderizan las sombras dinámicas. Valores más altos extienden las sombras a la distancia de renderizado; usa Shadow LOD para mantener el rendimiento en rangos extendidos.
value.shadowDistance.60.0=Cerca (60m)
value.shadowDistance.80.0=Estándar (80m)
value.shadowDistance.120.0=Lejos (120m)
value.shadowDistance.160.0=Ultra (160m)
value.shadowDistance.256.0=Extendida (256m)
value.shadowDistance.384.0=Distancia de Renderizado (384m)

option.SHADOW_LOD=Nivel de Detalle de Sombras
option.SHADOW_LOD.comment=Controla la degradación de la calidad de las sombras con la distancia. Con distancia de sombras extendida (256-384m), el LOD reduce el número de muestras y aumenta el radio del filtro a distancia para mantener el rendimiento. Desactivado = calidad uniforme (más lento). Equilibrado = reducción al 25-50% de la distancia. Agresivo = reducción máxima al 15-60% de la distancia. Las sombras se omiten por completo más allá del 95% de la distancia de renderizado.
value.SHADOW_LOD.0=Desactivado (Calidad Uniforme)
value.SHADOW_LOD.1=Equilibrado
value.SHADOW_LOD.2=Agresivo
option.SHADOW_PCSS_BLUR=Difuminado PCSS por Distancia
option.SHADOW_PCSS_BLUR.comment=Activa el suavizado de penumbra PCSS que aumenta el difuminado de las sombras con la distancia y durante la lluvia. Desactivar para suavidad fija (sombras lejanas más nítidas, menos realistas).
value.SHADOW_PCSS_BLUR.0=Desactivado (Suavidad Fija)
value.SHADOW_PCSS_BLUR.1=Activado (Penumbra PCSS)


option.AMBIENT_BRIGHTNESS=Elevación de Sombras (Ambiente)
option.AMBIENT_BRIGHTNESS.comment=Controla qué tan oscuras se ven las áreas sombreadas de noche y en cuevas.
value.AMBIENT_BRIGHTNESS.1=Oscuras
value.AMBIENT_BRIGHTNESS.2=Estándar
value.AMBIENT_BRIGHTNESS.3=Elevadas (Claras)

option.SHADOW_TINT=Tinte de Sombras
option.SHADOW_TINT.comment=Tinta las sombras diurnas. En la realidad, las sombras bajo un cielo azul tienen un sutil tono frío.
value.SHADOW_TINT.1=Gris Neutro
value.SHADOW_TINT.2=Azul Frío (Realista)
value.SHADOW_TINT.3=Cálido

option.LIGHT_WRAP=Envoltura de Luz (Light Wrap)
option.LIGHT_WRAP.comment=Suaviza el terminador entre superficies iluminadas y oscuras. Realista = Lambert físico; Suave = agradable para capturas.
value.LIGHT_WRAP.1=Realista (Lambert)
value.LIGHT_WRAP.2=Envoltura Suave
value.LIGHT_WRAP.3=Estilizada

