# ==============================================================================
# Extended shadow settings
# ==============================================================================
option.shadowDistance=Distance des Ombres
option.shadowDistance.comment=Distance maximale à laquelle les ombres dynamiques sont rendues. Des valeurs plus élevées étendent les ombres jusqu'à la distance de rendu; utilisez Shadow LOD pour maintenir les performances à des plages étendues.
value.shadowDistance.60.0=Près (60m)
value.shadowDistance.80.0=Standard (80m)
value.shadowDistance.120.0=Loin (120m)
value.shadowDistance.160.0=Ultra (160m)
value.shadowDistance.256.0=Étendue (256m)
value.shadowDistance.384.0=Distance de rendu (384m)

option.SHADOW_LOD=Niveau de détail des ombres
option.SHADOW_LOD.comment=Contrôle la dégradation de la qualité des ombres avec la distance. Avec une distance d'ombres étendue (256-384m), le LOD réduit le nombre d'échantillons et augmente le rayon du filtre à distance pour maintenir les performances. Désactivé = qualité uniforme (le plus lent). Équilibré = réduction à 25-50% de la distance. Agressif = réduction maximale à 15-60% de la distance. Les ombres sont complètement ignorées au-delà de 95% de la distance de rendu.
value.SHADOW_LOD.0=Désactivé (qualité uniforme)
value.SHADOW_LOD.1=Équilibré
value.SHADOW_LOD.2=Agressif
option.SHADOW_PCSS_BLUR=Flou PCSS à distance
option.SHADOW_PCSS_BLUR.comment=Active l'adoucissement de la pénombre PCSS qui augmente le flou des ombres avec la distance et pendant la pluie. Désactiver pour une douceur fixe (ombres lointaines plus nettes, moins réalistes).
value.SHADOW_PCSS_BLUR.0=Désactivé (douceur fixe)
value.SHADOW_PCSS_BLUR.1=Activé (pénombre PCSS)


option.AMBIENT_BRIGHTNESS=Levée d'Ombres (Ambient)
option.AMBIENT_BRIGHTNESS.comment=Contrôle l'obscurité des zones ombragées la nuit et dans les grottes.
value.AMBIENT_BRIGHTNESS.1=Sombres
value.AMBIENT_BRIGHTNESS.2=Standard
value.AMBIENT_BRIGHTNESS.3=Levées (Claires)

option.SHADOW_TINT=Teinte d'Ombre
option.SHADOW_TINT.comment=Teinte les ombres diurnes. Dans la réalité, les ombres sous un ciel bleu ont une subtile teinte froide.
value.SHADOW_TINT.1=Gris Neutre
value.SHADOW_TINT.2=Bleu Froid (Réaliste)
value.SHADOW_TINT.3=Chaud

option.LIGHT_WRAP=Enveloppement Lumineux
option.LIGHT_WRAP.comment=Adoucit le terminateur entre surfaces éclairées et obscures. Réaliste = Lambert physique ; Doux = agréable pour captures.
value.LIGHT_WRAP.1=Réaliste (Lambert)
value.LIGHT_WRAP.2=Enveloppement Doux
value.LIGHT_WRAP.3=Stylisé

