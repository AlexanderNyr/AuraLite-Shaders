# ==============================================================================
# Extended shadow settings
# ==============================================================================
option.shadowDistance=Shadow Distance
option.shadowDistance.comment=Maximum distance at which dynamic shadows are rendered. Higher values extend shadows to render distance; use Shadow LOD to maintain performance at extended ranges.
value.shadowDistance.60.0=Near (60m)
value.shadowDistance.80.0=Standard (80m)
value.shadowDistance.120.0=Far (120m)
value.shadowDistance.160.0=Ultra (160m)
value.shadowDistance.256.0=Extended (256m)
value.shadowDistance.384.0=Render Distance (384m)

option.SHADOW_LOD=Shadow LOD
option.SHADOW_LOD.comment=Controls shadow quality degradation with distance. With extended shadow distance (256-384m), LOD reduces sample count and increases filter radius at far range to maintain performance. Off = uniform quality (slowest). Balanced = reduction at 25-50% distance. Aggressive = maximum reduction at 15-60% distance. Shadows are fully skipped beyond 95% of render distance.
value.SHADOW_LOD.0=Off (Uniform Quality)
value.SHADOW_LOD.1=Balanced
value.SHADOW_LOD.2=Aggressive
option.SHADOW_PCSS_BLUR=PCSS Distance Blur
option.SHADOW_PCSS_BLUR.comment=Enable PCSS penumbra softening that increases shadow blur at distance and during rain. Disable for fixed shadow softness (sharper distant shadows, less realistic).
value.SHADOW_PCSS_BLUR.0=Off (Fixed Softness)
value.SHADOW_PCSS_BLUR.1=On (PCSS Penumbra)


option.AMBIENT_BRIGHTNESS=Shadow Lift / Ambient
option.AMBIENT_BRIGHTNESS.comment=Controls how dark shadowed areas appear at night and in caves.
value.AMBIENT_BRIGHTNESS.1=Dark
value.AMBIENT_BRIGHTNESS.2=Standard
value.AMBIENT_BRIGHTNESS.3=Lifted (Bright)

option.SHADOW_TINT=Shadow Tint
option.SHADOW_TINT.comment=Tints daytime shadows. Real-world shadows under a blue sky have a subtle cool tint.
value.SHADOW_TINT.1=Neutral Gray
value.SHADOW_TINT.2=Cool Blue (Realistic)
value.SHADOW_TINT.3=Warm

option.LIGHT_WRAP=Light Wrap
option.LIGHT_WRAP.comment=Softens the terminator between lit and unlit surfaces. Realistic = physical Lambert; Soft = pleasant for screenshots.
value.LIGHT_WRAP.1=Realistic (Lambert)
value.LIGHT_WRAP.2=Soft Wrap
value.LIGHT_WRAP.3=Stylized

