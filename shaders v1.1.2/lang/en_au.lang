# ==============================================================================
# Quality Profiles
# ==============================================================================
profile.VERY_LOW=Very Low
profile.VERY_LOW.comment=Absolute maximum FPS. All extras off: no shadows, no clouds, no PBR, no SSR, no godrays. Minimal rendering only.
profile.LOW=Low
profile.LOW.comment=Lightweight but playable. Keeps foliage/water animation, brighter stars, FXAA, vignette. No shadows, clouds or PBR.
profile.MED=Medium
profile.MED.comment=Everyday sweet spot. Shadows 1024, clouds, PBR, SSR Fast, godrays, foliage SSS, wet reflections, ground mist, shooting stars.
profile.HIGH=High
profile.HIGH.comment=Enthusiast quality. Shadows 2048, SSR Balanced, TAA, SSAO Subtle, godrays Balanced, SMAA.
profile.ULTRA=Ultra
profile.ULTRA.comment=High-end. Shadows 4096, SSR High, SSAO Balanced, godrays High, TAA Stable, all effects on.
profile.EXTREME=Extreme
profile.EXTREME.comment=Cinematic max. Everything maxed: PBR Unlimited range, Photographic (AgX) tone map, deepest SSAO, meteor storms.
profile.CUSTOM=Custom
profile.CUSTOM.comment=Custom user-modified settings.

screen.TRANSLATION_NOTICE=⚠ Translations may contain errors
screen.TRANSLATION_NOTICE.comment=Some localization strings may be inaccurate. If something looks strange, compare with the English original.

