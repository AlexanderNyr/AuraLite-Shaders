# ==============================================================================
# Extended shadow settings
# ==============================================================================
option.shadowDistance=Kölgə məsafəsi
option.shadowDistance.comment=Dinamik kölgələrin render edildiyi maksimum məsafə. Daha yüksək dəyərlər kölgələri render məsafəsinə qədər genişləndirir; genişləndirilmiş diapazonlarda performansı qorumaq üçün Shadow LOD istifadə edin.
value.shadowDistance.60.0=Yaxın (60m)
value.shadowDistance.80.0=Standart (80m)
value.shadowDistance.120.0=Uzaq (120m)
value.shadowDistance.160.0=Ultra (160 m)
value.shadowDistance.256.0=Genişləndirilmiş (256 m)
value.shadowDistance.384.0=Render məsafəsi (384 m)

option.SHADOW_LOD=Kölgə LOD
option.SHADOW_LOD.comment=Kölgələrin keyfiyyətinin məsafə ilə pisləşməsini idarə edir. Genişləndirilmiş kölgə məsafəsində (256-384 m) LOD performansı qorumaq üçün nümunə sayını azaldır və uzaq məsafədə filtr radiusunu artırır. Bağlı = bərabər keyfiyyət (yavaş). Balanslaşdırılmış = 25-50% məsafədə azaltma. Aqressiv = 15-60% məsafədə maksimum azaltma. Kölgələr render məsafəsinin 95%-ndən sonra tamamilə buraxılır.
value.SHADOW_LOD.0=Bağlı (bərabər keyfiyyət)
value.SHADOW_LOD.1=Balanslaşdırılmış
value.SHADOW_LOD.2=Aqressiv
