# ==============================================================================
# Розширені налаштування тіней
# ==============================================================================
option.shadowDistance=Дальність тіней
option.shadowDistance.comment=Максимальна відстань рендеру динамічних тіней. Вищі значення розширюють тіні до відстані рендеру; використовуйте Shadow LOD для підтримки продуктивності на розширених дистанціях.
value.shadowDistance.60.0=Близько (60м)
value.shadowDistance.80.0=Стандартно (80м)
value.shadowDistance.120.0=Далеко (120м)
value.shadowDistance.160.0=Ультра (160м)
value.shadowDistance.256.0=Розширена (256 м)
value.shadowDistance.384.0=Відстань рендеру (384 м)

option.SHADOW_LOD=LOD тіней
option.SHADOW_LOD.comment=Контролює зниження якості тіней з відстанню. При розширеній відстані тіней (256-384 м) LOD зменшує кількість вибірок і збільшує радіус фільтра на дальніх відстанях для підтримки продуктивності. Вимк = рівномірна якість (повільно). Збалансований = зниження на 25-50% відстані. Агресивний = максимальне зниження на 15-60% відстані. Тіні повністю пропускаються за межами 95% відстані рендеру.
value.SHADOW_LOD.0=Вимк (рівномірна якість)
value.SHADOW_LOD.1=Збалансований
value.SHADOW_LOD.2=Агресивний
option.SHADOW_PCSS_BLUR=PCSS розмиття по відстані
option.SHADOW_PCSS_BLUR.comment=Вмикає PCSS пом'якшення напівтіні, яке збільшує розмиття тіней з відстанню та під час дощу. Вимкніть для фіксованої м'якості (чіткіші далекі тіні, менш реалістично).
value.SHADOW_PCSS_BLUR.0=Вимк (фіксована м'якість)
value.SHADOW_PCSS_BLUR.1=Увімк (PCSS напівтінь)

option.AMBIENT_BRIGHTNESS=Підняття тіней / Оточення
option.AMBIENT_BRIGHTNESS.comment=Керує тим, наскільки темними виглядають затінені ділянки вночі та в печерах.
value.AMBIENT_BRIGHTNESS.1=Темна
value.AMBIENT_BRIGHTNESS.2=Стандартна
value.AMBIENT_BRIGHTNESS.3=Піднята (яскрава)
option.SHADOW_TINT=Відтінок тіні
option.SHADOW_TINT.comment=Забарвлює денні тіні. У реальному світі тіні під блакитним небом мають легкий холодний відтінок.
