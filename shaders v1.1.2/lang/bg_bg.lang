value.CLOUD_DISTANCE.3=Далеко
value.CLOUD_DISTANCE.4=Много далеко

option.CLOUD_SHADOWS=Сенки от облаци
option.CLOUD_SHADOWS.comment=Добавя прозрачни процедурни сенки от плътността на обемните облаци върху терена. Балансирано от профилите на качество.
option.CLOUD_SHADOW_STRENGTH=Сила на сенките от облаци
option.CLOUD_SHADOW_STRENGTH.comment=Контролира колко видими и драматични са прозрачните сенки от облаци.
value.CLOUD_SHADOW_STRENGTH.1=Меко
value.CLOUD_SHADOW_STRENGTH.2=Балансирано
value.CLOUD_SHADOW_STRENGTH.3=Драматично

option.GODRAYS=Слънчеви лъчи (Godrays)
option.GODRAYS.comment=Adds physically-inspired volumetric single-scattering sun shafts with Beer-Lambert extinction, Mie phase and shadow-map occlusion.
option.GODRAYS_QUALITY=Качество на Godrays
option.GODRAYS_QUALITY.comment=Controls the sample count and integration distance of physically-based volumetric godrays.
value.GODRAYS_QUALITY.1=Бързо
value.GODRAYS_QUALITY.2=Балансирано
value.GODRAYS_QUALITY.3=Високо

option.AURORA_MODE=Северно сияние
option.AURORA_MODE.comment=Контролирайте показването на реалистично течащо северно сияние в нощното небе.

value.AURORA_MODE.0=Изключено
value.AURORA_MODE.1=Само в студени биоми
value.AURORA_MODE.2=Винаги активно

option.AURORA_SPEED=Скорост на сиянието
option.AURORA_SPEED.comment=Контролирайте скоростта на полюшване и течене на северното сияние.

value.AURORA_SPEED.1=Бавно
value.AURORA_SPEED.2=Стандартна
value.AURORA_SPEED.3=Бързо

option.AURORA_STRENGTH=Яркост на сиянието
