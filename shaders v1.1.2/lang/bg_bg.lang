value.CONTRAST.2=Филмово (ACES)
value.CONTRAST.3=Интензивно (Висок контраст)

option.TAA=Времево изглаждане (TAA)
option.TAA.comment=Времево разрешаване с репроекция на движението и изрязване на съседство. Намалява трептенето и назъбените ръбове при високи настройки.
option.TAA_STRENGTH=Сила на TAA
option.TAA_STRENGTH.comment=Контролира смесването на историята. По-високата стойност е по-стабилна, но може да е по-мека при движение.
value.TAA_STRENGTH.1=Леко
value.TAA_STRENGTH.2=Балансирано
value.TAA_STRENGTH.3=Стабилно

option.VIGNETTE=Ефект на винетиране
option.VIGNETTE.comment=Активирайте леко потъмняване по краищата на екрана за подобрен фокус.

option.WATER_RIFFLES=Сила на водните вълнички
option.WATER_RIFFLES.comment=Adjust the waviness and intensity of the fine normal map ripples on the water.

value.WATER_RIFFLES.1=Спокойно
value.WATER_RIFFLES.2=Стандартна
value.WATER_RIFFLES.3=Развълнувано

option.WATER_SPECULAR_STRENGTH=Отблясък на водата
option.WATER_SPECULAR_STRENGTH.comment=Adjust the brightness of sun/moon reflections on the water ripples.

value.WATER_SPECULAR_STRENGTH.1=Меко
value.WATER_SPECULAR_STRENGTH.2=Стандартна
value.WATER_SPECULAR_STRENGTH.3=Блестящо

option.SHADOW_SOFTNESS=Мекота на сенките
option.SHADOW_SOFTNESS.comment=Контролира колко меки и дифузни изглеждат ръбовете на сенките. Използва завъртяно филтриране с диск на Поасон за гладка полусянка.

value.SHADOW_SOFTNESS.1=Остро
value.SHADOW_SOFTNESS.2=Меко
value.SHADOW_SOFTNESS.3=Ултра меко

# ==============================================================================
# Sun & Moon Lighting (extended)
# ==============================================================================
screen.SUN_MOON=Слънце и Луна
screen.SUN_MOON.comment=Прецизирайте интензитета на слънцето и луната, цветовата температура и атмосферните ефекти.

option.SUN_INTENSITY=Интензитет на слънцето
option.SUN_INTENSITY.comment=Основна яркост на директната слънчева светлина. По-високо: по-силен дневен контраст.
value.SUN_INTENSITY.1=Слабо
