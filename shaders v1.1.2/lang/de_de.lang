# ==============================================================================
# Erweiterte Schatteneinstellungen
# ==============================================================================
option.shadowDistance=Schattenreichweite
option.shadowDistance.comment=Maximale Entfernung, in der dynamische Schatten gerendert werden. Höhere Werte erweitern die Schatten auf die Renderdistanz; verwenden Sie Shadow LOD, um die Leistung bei erweiterten Bereichen aufrechtzuerhalten.
value.shadowDistance.60.0=Nah (60m)
value.shadowDistance.80.0=Standard (80 m)
value.shadowDistance.120.0=Weit (120m)
value.shadowDistance.160.0=Ultra (160 m)
value.shadowDistance.256.0=Erweitert (256 m)
value.shadowDistance.384.0=Render-Distanz (384 m)

option.SHADOW_LOD=Schatten-LOD
option.SHADOW_LOD.comment=Steuert die Qualitätsverringerung der Schatten mit zunehmender Entfernung. Bei erweiterter Schattenentfernung (256-384 m) reduziert LOD die Sample-Anzahl und erhöht den Filter-Radius in der Ferne, um die Leistung beizubehalten. Aus = gleichmäßige Qualität (langsam). Balanciert = Reduktion bei 25-50% Distanz. Aggressiv = maximale Reduktion bei 15-60% Distanz. Schatten werden jenseits von 95% der Render-Distanz vollständig übersprungen.
value.SHADOW_LOD.0=Aus (gleichmäßige Qualität)
value.SHADOW_LOD.1=Balanciert
value.SHADOW_LOD.2=Aggressiv
option.SHADOW_PCSS_BLUR=PCSS-Abstandsunschärfe
option.SHADOW_PCSS_BLUR.comment=Aktiviert PCSS-Penumbra-Erweichung, die Schattenunschärfe mit der Entfernung und bei Regen erhöht. Deaktivieren für feste Schattenweichheit (schärfere Fernschatten, weniger realistisch).
value.SHADOW_PCSS_BLUR.0=Aus (feste Weichheit)
value.SHADOW_PCSS_BLUR.1=An (PCSS-Penumbra)


option.AMBIENT_BRIGHTNESS=Schatten-Anhebung (Ambient)
option.AMBIENT_BRIGHTNESS.comment=Steuert, wie dunkel Schattenbereiche nachts und in Höhlen erscheinen.
value.AMBIENT_BRIGHTNESS.1=Dunkel
value.AMBIENT_BRIGHTNESS.2=Standard
value.AMBIENT_BRIGHTNESS.3=Angehoben (Hell)

option.SHADOW_TINT=Schattentönung
option.SHADOW_TINT.comment=Färbt Tagschatten ein. In der Realität haben Schatten unter blauem Himmel einen subtilen kühlen Ton.
value.SHADOW_TINT.1=Neutrales Grau
value.SHADOW_TINT.2=Kühles Blau (Realistisch)
value.SHADOW_TINT.3=Warm

option.LIGHT_WRAP=Lichtumhüllung (Light Wrap)
option.LIGHT_WRAP.comment=Mildert den Terminator zwischen beleuchteten und unbeleuchteten Flächen. Realistisch = physikalischer Lambert; Weich = angenehm für Screenshots.
value.LIGHT_WRAP.1=Realistisch (Lambert)
value.LIGHT_WRAP.2=Weiche Umhüllung
value.LIGHT_WRAP.3=Stilisiert

