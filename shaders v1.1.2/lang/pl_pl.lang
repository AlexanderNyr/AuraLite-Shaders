value.shadowMapResolution.2048=2048
value.shadowMapResolution.4096=4096
option.POM_DEPTH=Głębokość POM
option.POM_DEPTH.comment=Kontroluje widoczną głębokość mapowania paralaksy przy włączonym PBR POM.
value.POM_DEPTH.1=Niska
value.POM_DEPTH.2=Standardowa
value.POM_DEPTH.3=Głęboka
option.POM_STEPS=Kroki POM
option.POM_STEPS.comment=Kontroluje liczbę kroków raymarch dla mapowania paralaksy. Wyższe wartości poprawiają jakość, ale kosztują więcej czasu GPU.
value.POM_STEPS.1=Szybki
value.POM_STEPS.2=Standardowa
value.POM_STEPS.3=Wysoki
value.POM_STEPS.4=Ultra

screen.SHADOW_OPTIONS=Cienie
screen.SHADOW_OPTIONS.comment=Rozdzielczość, odległość, miękkość i odcień dynamicznych cieni.
screen.PBR_OPTIONS=PBR i materiały
screen.PBR_OPTIONS.comment=Oświetlenie PBR, relief paralaksy, intensywność i odległość renderowania.
screen.AO_REFLECTIONS=AO i odbicia
screen.AO_REFLECTIONS.comment=SSAO, odbicia ekranowe i odbicia deszczu.
screen.CLOUD_SHAPE=Chmury
screen.CLOUD_SHAPE.comment=Kształt, wysokość, odległość i cienie chmur wolumetrycznych.
screen.LIGHT_SHAFTS=Promienie światła
screen.LIGHT_SHAFTS.comment=Wolumetryczne promienie słońca/księżyca i ich jakość/intensywność.
screen.NIGHT_SKY=Nocne niebo
screen.NIGHT_SKY.comment=Zorza, gwiazdy, Droga Mleczna i spadające gwiazdy.
