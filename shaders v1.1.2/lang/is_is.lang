value.shadowDistance.80.0=Staðlað (80m)
value.shadowDistance.120.0=Fjarri (120m)
value.shadowDistance.160.0=Ultra (160 m)
value.shadowDistance.256.0=Lengt (256 m)
value.shadowDistance.384.0=Renderingsfjarlægð (384 m)

option.SHADOW_LOD=Skugga LOD
option.SHADOW_LOD.comment=Stýrir skugga gæða rýrnun með fjarlægð. Með útbreiddri skugga fjarlægð (256-384 m) dregur LOD úr sýnafjölda og eykur síunaradius í fjarlægð til að viðhalda afköstum. Slökkt = jöfn gæði (hægt). Jafnvægi = minnkun við 25-50% fjarlægð. Árásargjarn = hámarks minnkun við 15-60% fjarlægð. Skuggar eru alveg slepptir fyrir utan 95% af renderingsfjarlægð.
value.SHADOW_LOD.0=Slökkt (jöfn gæði)
value.SHADOW_LOD.1=Jafnvægi
value.SHADOW_LOD.2=Árásargjarn
option.SHADOW_PCSS_BLUR=PCSS fjarlægðarþoka
option.SHADOW_PCSS_BLUR.comment=Virkjar PCSS hálfskugga mýkingu sem eykur skugga þoku með fjarlægð og í rigningu. Slökkva fyrir fastan mýkt (skarpari fjarlægir skuggar, minna raunhæft).
value.SHADOW_PCSS_BLUR.0=Slökkt (fastur mýkt)
value.SHADOW_PCSS_BLUR.1=Kveikt (PCSS hálfskuggi)


