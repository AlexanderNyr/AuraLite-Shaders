# ==============================================================================
# Impostazioni ombre estese
# ==============================================================================
option.shadowDistance=Distanza Ombre
option.shadowDistance.comment=Distanza massima alla quale vengono renderizzate le ombre dinamiche. Valori più alti estendono le ombre alla distanza di rendering; usa Shadow LOD per mantenere le prestazioni a intervalli estesi.
value.shadowDistance.60.0=Vicina (60m)
value.shadowDistance.80.0=Standard (80 m)
value.shadowDistance.120.0=Lontana (120m)
value.shadowDistance.160.0=Ultra (160 m)
value.shadowDistance.256.0=Estesa (256 m)
value.shadowDistance.384.0=Distanza di rendering (384 m)

option.SHADOW_LOD=LOD ombre
option.SHADOW_LOD.comment=Controlla la degradazione della qualità delle ombre con la distanza. Con la distanza delle ombre estesa (256-384 m), il LOD riduce il numero di campioni e aumenta il raggio del filtro a distanza per mantenere le prestazioni. Off = qualità uniforme (lento). Bilanciato = riduzione al 25-50% della distanza. Aggressivo = riduzione massima al 15-60% della distanza. Le ombre sono completamente saltate oltre il 95% della distanza di rendering.
value.SHADOW_LOD.0=Off (qualità uniforme)
value.SHADOW_LOD.1=Bilanciato
value.SHADOW_LOD.2=Aggressivo
option.SHADOW_PCSS_BLUR=Sfocatura PCSS per distanza
option.SHADOW_PCSS_BLUR.comment=Attiva l'ammorbidimento della penombra PCSS che aumenta la sfocatura delle ombre con la distanza e durante la pioggia. Disattiva per morbidezza fissa (ombre lontane più nitide, meno realistiche).
value.SHADOW_PCSS_BLUR.0=Off (morbidezza fissa)
value.SHADOW_PCSS_BLUR.1=On (penombra PCSS)


option.AMBIENT_BRIGHTNESS=Sollevamento Ombre (Ambient)
option.AMBIENT_BRIGHTNESS.comment=Controlla quanto le aree in ombra appaiano scure di notte e nelle caverne.
value.AMBIENT_BRIGHTNESS.1=Scure
value.AMBIENT_BRIGHTNESS.2=Standard
value.AMBIENT_BRIGHTNESS.3=Sollevate (Chiare)

option.SHADOW_TINT=Tinta Ombra
option.SHADOW_TINT.comment=Tinge le ombre diurne. Nella realtà, le ombre sotto un cielo blu hanno una sottile tinta fredda.
value.SHADOW_TINT.1=Grigio Neutro
value.SHADOW_TINT.2=Blu Freddo (Realistico)
value.SHADOW_TINT.3=Caldo

option.LIGHT_WRAP=Avvolgimento Luce (Light Wrap)
option.LIGHT_WRAP.comment=Ammorbidisce il terminatore tra superfici illuminate e oscure. Realistico = Lambert fisico; Morbido = piacevole per screenshot.
value.LIGHT_WRAP.1=Realistico (Lambert)
value.LIGHT_WRAP.2=Avvolgimento Morbido
value.LIGHT_WRAP.3=Stilizzato

