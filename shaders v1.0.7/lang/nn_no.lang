value.SHOOTING_STARS_FREQUENCY.3=Meteorstorm

option.SHOOTING_STARS_BRIGHTNESS=Magnitudeskala
option.SHOOTING_STARS_BRIGHTNESS.comment=Hovudmultiplikator på meteormagnitudeskalaen. Svak = realistisk gjennomsnitt; Lys = skalerer eldkuler for filmatisk synlegheit.

