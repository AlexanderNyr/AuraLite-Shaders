# ==============================================================================
# Kvalitetsprofilar — Rebalansering v1.0.5
# ==============================================================================
profile.VERY_LOW=Svært låg
profile.VERY_LOW.comment=Absolutt maksimal FPS. Alle ekstrafunksjonar av: ingen skuggar, ingen skyer, ingen PBR, ingen SSR, ingen solstrålar. Berre minimal gjengjeving.
profile.LOW=Låg
profile.LOW.comment=Lett, men speleleg. Held på vegetasjon-/vassrørsle, lysare stjerner, FXAA, vignett. Ingen skuggar, skyer eller PBR.
profile.MED=Middels
profile.MED.comment=Dagleg godt val. Skuggar 1024, skyer, PBR, SSR Rask, solstrålar, lauvverk-SSS, våte refleksar, bakkedis, stjerneskot.
profile.HIGH=Høg
profile.HIGH.comment=Entusiastkvalitet. Skuggar 2048, SSR Balansert, TAA, SSAO Subtil, solstrålar Balansert, SMAA.
profile.ULTRA=Ultra
profile.ULTRA.comment=Toppklasse. Skuggar 4096, SSR Høg, SSAO Balansert, solstrålar Høg, TAA Stabil, alle effektar på.
profile.EXTREME=Ekstrem
profile.EXTREME.comment=Filmatisk maksimum. Alt maksimert: PBR Uavgrensa rekkjevidde, Fotografisk (AgX) tonekartlegging, djupaste SSAO, meteorstormar.
profile.CUSTOM=Tilpassa
profile.CUSTOM.comment=Tilpassa brukarendra innstillingar.

screen.TRANSLATION_NOTICE=⚠ Omsetjingar kan innehalde feil
screen.TRANSLATION_NOTICE.comment=Nokre lokaliseringsstrengar kan vere unøyaktige. Om noko ser rart ut, samanlikn med den engelske originalen.

