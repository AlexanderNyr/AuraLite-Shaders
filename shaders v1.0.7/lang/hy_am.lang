value.SUN_TEMPERATURE.2=Իրատեսական
value.SUN_TEMPERATURE.3=Տաք ոսկեգույն

option.MOON_TEMPERATURE=Լուսնի գույնի ջերմաստիճան
option.MOON_TEMPERATURE.comment=Լուսնի լույսի երանգ։ Սառցե = կապտավուն սառը; Արծաթ = իրատեսական 4100K; Տաք = բերքի լուսնի կրեմ։
