value.MOON_TEMPERATURE.2=Արծաթ (Իրատեսական)
value.MOON_TEMPERATURE.3=Տաք կրեմ

option.SUN_HALO=Արևի լուսապսակ (Mie ցրում)
option.SUN_HALO.comment=Ավելացնում է փափուկ տաք շող տեղանքի վրա, երբ նայում եք արևի մոտ (Mie առաջընթաց ցրում)։

option.SUNRISE_GLOW=Ուժեղացված արևածագի/մայրամուտի շող
option.SUNRISE_GLOW.comment=Միացնում է ավելի ուժեղ տաք հետընթաց ցրում, որը պարուրում է ցածր արևից շեղված մակերեսները։

# ==============================================================================
# Extended shadow settings
# ==============================================================================
option.SHADOW_DISTANCE=Ստվերների հեռավորություն
option.SHADOW_DISTANCE.comment=Առավելագույն հեռավորություն, որով դինամիկ ստվերները ռենդերվում են մարելուց առաջ։
value.SHADOW_DISTANCE.1=Մոտ (60մ)
value.SHADOW_DISTANCE.2=Ստանդարտ (80մ)
value.SHADOW_DISTANCE.3=Հեռու (120մ)
value.SHADOW_DISTANCE.4=Ուլտրա (160մ)

option.AMBIENT_BRIGHTNESS=Ստվերի բարձրացում / Շրջակա միջավայր
option.AMBIENT_BRIGHTNESS.comment=Կառավարում է, թե որքան մուգ են երևում ստվերապատ տարածքները գիշերը և քարանձավներում։
value.AMBIENT_BRIGHTNESS.1=Մուգ
value.AMBIENT_BRIGHTNESS.2=Ստանդարտ
value.AMBIENT_BRIGHTNESS.3=Բարձրացված (Պայծառ)

option.SHADOW_TINT=Ստվերի երանգ
option.SHADOW_TINT.comment=Երանգավորում է ցերեկային ստվերները։ Կապույտ երկնքի տակ իրական ստվերներն ունեն նուրբ սառը երանգ։
value.SHADOW_TINT.1=Չեզոք մոխրագույն
value.SHADOW_TINT.2=Սառը կապույտ (Իրատեսական)
value.SHADOW_TINT.3=Տաք

option.LIGHT_WRAP=Լույսի փաթաթում
option.LIGHT_WRAP.comment=Մեղմացնում է լուսավորված և չլուսավորված մակերեսների միջև սահմանը։ Իրատեսական = ֆիզիկական Lambert; Փափուկ = հաճելի սքրինշոթերի համար։
value.LIGHT_WRAP.1=Իրատեսական (Lambert)
value.LIGHT_WRAP.2=Փափուկ փաթաթում
value.LIGHT_WRAP.3=Ոճավորված

# ==============================================================================
# Screen-Space Reflections (SSR)
# ==============================================================================
option.SSR=Էկրանային տարածության անդրադարձումներ (SSR)
option.SSR.comment=Ավելացնում է իրական ժամանակի անդրադարձված միջավայր ջրի, թաց մակերեսների և մետաղական PBR բլոկների վրա։ Միացված է ՄԻՋԻՆից վերև։

option.SSR_QUALITY=SSR որակ
option.SSR_QUALITY.comment=Կառավարում է էկրանային տարածության անդրադարձումների ճշգրտությունն ու ճառագայթի հեռավորությունը։ Ավելի բարձր = ավելի սուր անդրադարձումներ, բայց ավելի շատ GPU ծախս։
