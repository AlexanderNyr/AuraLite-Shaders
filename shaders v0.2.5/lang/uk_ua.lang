value.AURORA_MODE.1=Лише в холодних біомах
value.AURORA_MODE.2=Завжди увімкнено
option.AURORA_SPEED=Швидкість Сяйва
option.AURORA_SPEED.comment=Керує швидкістю хвилювання та плину полярного сяйва.
value.AURORA_SPEED.1=Повільна
value.AURORA_SPEED.2=Стандартна
value.AURORA_SPEED.3=Швидка
option.AURORA_STRENGTH=Яскравість Сяйва
option.AURORA_STRENGTH.comment=Керує загальною яскравістю полярного сяйва.
