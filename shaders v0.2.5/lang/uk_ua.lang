# Screens
screen.LIGHTING=Налаштування Освітлення
screen.LIGHTING.comment=Налаштуйте тіні, кольори світла та яскравість.
screen.FOLIAGE=Налаштування Рослинності
screen.FOLIAGE.comment=Налаштуйте анімації колихання трави та листя.
screen.WATER=Налаштування Води
screen.WATER.comment=Налаштуйте хвилі, прозорість і стиль води.
screen.CLOUDS_MENU=Небо та Хмари
screen.CLOUDS_MENU.comment=Налаштуйте фізичну висоту, товщину та стиль 3D-хмар і ефекти неба.
screen.POST_PROCESS=Постобробка та Туман
screen.POST_PROCESS.comment=Налаштуйте експозицію, туман та кінематографічні ефекти.

# Options
option.SHADOWS=Динамічні Тіні
option.SHADOWS.comment=Вмикає або вимикає м'які динамічні тіні від сонця та місяця.
option.SHADOW_RES=Роздільна Здатність Тіней
option.SHADOW_RES.comment=Змінює якість карти тіней. Вищі значення знижують продуктивність.
option.PBR_LIGHTING=PBR Освітлення (LabPBR)
option.PBR_LIGHTING.comment=Вмикає фізично-коректний рендеринг металів, шорсткості та 3D-карт нормалей (потрібен PBR-ресурспак).
option.PBR_POM=3D-Рельєф Блоків (POM)
option.PBR_POM.comment=Вмикає Parallax Occlusion Mapping для справжніх 3D-текстур блоків. Рекомендовано вимкнути для несумісних паків.
option.PBR_STRENGTH=Інтенсивність PBR
option.PBR_STRENGTH.comment=Керує відбивністю та глянцем PBR-металевих поверхонь.
value.PBR_STRENGTH.1=Помірна
value.PBR_STRENGTH.2=Стандартна
value.PBR_STRENGTH.3=Дзеркальна
option.LIGHTMAP_WARMTH=Теплота Смолоскипів
option.LIGHTMAP_WARMTH.comment=Регулює теплоту та колір світла блоків/смолоскипів.
value.LIGHTMAP_WARMTH.1=Затишна
value.LIGHTMAP_WARMTH.2=Тепла
value.LIGHTMAP_WARMTH.3=Насичена
option.WAVING_LEAVES=Колихання Листя
option.WAVING_LEAVES.comment=Вмикає м'які анімації колихання листя дерев.
option.WAVING_GRASS=Колихання Рослин
option.WAVING_GRASS.comment=Вмикає анімації колихання трави, квітів та культур.
option.WIND_SPEED=Швидкість Вітру
option.WIND_SPEED.comment=Керує швидкістю колихання листя, рослин та водних хвиль.
value.WIND_SPEED.1=Штиль
value.WIND_SPEED.2=Бриз
value.WIND_SPEED.3=Шторм
option.WATER_WAVES=Хвилі на Воді
option.WATER_WAVES.comment=Вмикає 3D-геометричні хвилі на поверхні води.
option.WATER_TRANSPARENCY=Щільність Води
option.WATER_TRANSPARENCY.comment=Керує прозорістю та непрозорістю води.
value.WATER_TRANSPARENCY.1=Кришталева
value.WATER_TRANSPARENCY.2=Збалансована
value.WATER_TRANSPARENCY.3=Глибока
option.PROCEDURAL_CLOUDS=Об'ємні 3D-Хмари
option.PROCEDURAL_CLOUDS.comment=Вмикає фізично прохідні 3D-хмари, крізь які можна пролетіти.
option.CLOUD_HEIGHT=Висота Хмар
option.CLOUD_HEIGHT.comment=Задає фізичну висоту (рівень Y) шару хмар у світі (у метрах).
value.CLOUD_HEIGHT.1=Низька (~110м)
value.CLOUD_HEIGHT.2=Стандартна (~160м)
value.CLOUD_HEIGHT.3=Висока (~240м)
option.CLOUD_THICKNESS=Товщина Хмар
option.CLOUD_THICKNESS.comment=Задає вертикальну товщину та об'єм хмар.
value.CLOUD_THICKNESS.1=Тонкі (Циррус)
value.CLOUD_THICKNESS.2=Стандартні (Кумулус)
value.CLOUD_THICKNESS.3=Щільні (Грозові)
