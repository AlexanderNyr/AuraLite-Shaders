value.SHADOW_SOFTNESS.2=Weich
value.SHADOW_SOFTNESS.3=Ultra Weich

# ==============================================================================
# Sonne & Mond Beleuchtung (erweitert)
# ==============================================================================
screen.SUN_MOON=Sonne & Mond
screen.SUN_MOON.comment=Feinabstimmung von Intensität, Farbtemperatur und Atmosphäre von Sonne und Mond.

option.SUN_INTENSITY=Sonnenintensität
option.SUN_INTENSITY.comment=Haupthelligkeit des direkten Sonnenlichts. Höher = stärkerer Tageskontrast.
value.SUN_INTENSITY.1=Matt
value.SUN_INTENSITY.2=Standard
value.SUN_INTENSITY.3=Hell
value.SUN_INTENSITY.4=Glühend

option.MOON_INTENSITY=Mondintensität
option.MOON_INTENSITY.comment=Haupthelligkeit des Mondlichts. Höher = hellere, sichtbarere Nächte.
value.MOON_INTENSITY.1=Stockfinstere Nacht
value.MOON_INTENSITY.2=Standard
value.MOON_INTENSITY.3=Heller Mond
value.MOON_INTENSITY.4=Helle Nacht

option.SUN_TEMPERATURE=Sonnenfarbtemperatur
option.SUN_TEMPERATURE.comment=Verschiebt die Kelvin-Kurve der Sonne. Realistisch nutzt Tanner-Helland-Schwarzkörper; warm = golden; kühl = neutralweiß.
value.SUN_TEMPERATURE.1=Kühl / Neutral
value.SUN_TEMPERATURE.2=Realistisch
value.SUN_TEMPERATURE.3=Warm Golden

option.MOON_TEMPERATURE=Mondfarbtemperatur
option.MOON_TEMPERATURE.comment=Farbton des Mondlichts. Eisig = bläulich kalt; Silbern = realistisch 4100K; Warm = Erntemond-Creme.
value.MOON_TEMPERATURE.1=Eisig Blau
value.MOON_TEMPERATURE.2=Silbern (Realistisch)
value.MOON_TEMPERATURE.3=Warmes Creme

option.SUN_HALO=Sonnen-Halo (Mie)
option.SUN_HALO.comment=Fügt ein weiches warmes Leuchten auf dem Gelände hinzu, wenn man in Richtung Sonne blickt (Mie-Vorwärtsstreuung).

option.SUNRISE_GLOW=Verstärktes Morgenrot/Abendglühen
option.SUNRISE_GLOW.comment=Aktiviert ein stärkeres warmes Rückstreu-Leuchten, das sich um abgewandte Flächen bei tief stehender Sonne legt.

# ==============================================================================
# Erweiterte Schatteneinstellungen
# ==============================================================================
option.SHADOW_DISTANCE=Schattenreichweite
option.SHADOW_DISTANCE.comment=Maximale Entfernung, bis zu der dynamische Schatten gerendert werden, bevor sie ausblenden.
value.SHADOW_DISTANCE.1=Nah (60m)
value.SHADOW_DISTANCE.2=Standard (80m)
value.SHADOW_DISTANCE.3=Weit (120m)
value.SHADOW_DISTANCE.4=Ultra (160m)

option.AMBIENT_BRIGHTNESS=Schatten-Anhebung (Ambient)
option.AMBIENT_BRIGHTNESS.comment=Steuert, wie dunkel Schattenbereiche nachts und in Höhlen erscheinen.
value.AMBIENT_BRIGHTNESS.1=Dunkel
value.AMBIENT_BRIGHTNESS.2=Standard
value.AMBIENT_BRIGHTNESS.3=Angehoben (Hell)

option.SHADOW_TINT=Schattentönung
option.SHADOW_TINT.comment=Färbt Tagschatten ein. In der Realität haben Schatten unter blauem Himmel einen subtilen kühlen Ton.
value.SHADOW_TINT.1=Neutrales Grau
value.SHADOW_TINT.2=Kühles Blau (Realistisch)
value.SHADOW_TINT.3=Warm

option.LIGHT_WRAP=Lichtumhüllung (Light Wrap)
option.LIGHT_WRAP.comment=Mildert den Terminator zwischen beleuchteten und unbeleuchteten Flächen. Realistisch = physikalischer Lambert; Weich = angenehm für Screenshots.
value.LIGHT_WRAP.1=Realistisch (Lambert)
value.LIGHT_WRAP.2=Weiche Umhüllung
value.LIGHT_WRAP.3=Stilisiert
