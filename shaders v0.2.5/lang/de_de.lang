# Screens
screen.LIGHTING=Beleuchtungseinstellungen
screen.LIGHTING.comment=Konfiguriere Schatten, Lichtfarben und Helligkeit.

screen.FOLIAGE=Vegetationseinstellungen
screen.FOLIAGE.comment=Konfiguriere Bewegungsanimationen für Gras und Blätter.

screen.WATER=Wassereinstellungen
screen.WATER.comment=Konfiguriere Wellen, Transparenz und Wasserstil.

screen.CLOUDS_MENU=Himmel & Wolken
screen.CLOUDS_MENU.comment=Konfiguriere Höhe, Dicke und Stil der 3D-Wolken sowie Himmeleffekte.

screen.POST_PROCESS=Nachbearbeitung & Nebel
screen.POST_PROCESS.comment=Konfiguriere Belichtung, Nebel und filmische Effekte.

# Options
option.SHADOWS=Dynamische Schatten
option.SHADOWS.comment=Aktiviert oder deaktiviert weiche dynamische Schatten von Sonne und Mond.

option.SHADOW_RES=Schattenauflösung
option.SHADOW_RES.comment=Ändert die Qualität der Schattenkarte. Höhere Werte verringern die Leistung.

option.PBR_LIGHTING=PBR-Beleuchtung (LabPBR)
option.PBR_LIGHTING.comment=Aktiviert physisch-basiertes Rendering für Metalle, Rauheit und 3D-Normal-Maps (PBR-Pack erforderlich).

option.PBR_POM=3D-Blockrelief (POM)
option.PBR_POM.comment=Aktiviert Parallax Occlusion Mapping für echte 3D-Texturen. Bei inkompatiblen Packs deaktivieren.

option.PBR_STRENGTH=PBR-Intensität
option.PBR_STRENGTH.comment=Steuert die Reflektivität und den Glanz von PBR-Metallflächen.

value.PBR_STRENGTH.1=Dezent
value.PBR_STRENGTH.2=Standard
value.PBR_STRENGTH.3=Spiegelnd

option.SSAO=SSAO / SAO Occlusion
option.SSAO.comment=Extreme profile: screen-space ambient occlusion for contact shadows in corners, under blocks, and around geometry intersections.
option.SSAO_STRENGTH=SSAO Strength
option.SSAO_STRENGTH.comment=Controls the depth of screen-space ambient occlusion. Only active when SSAO is enabled.
value.SSAO_STRENGTH.1=Subtle
value.SSAO_STRENGTH.2=Balanced
value.SSAO_STRENGTH.3=Deep

option.LIGHTMAP_WARMTH=Fackelwärme
option.LIGHTMAP_WARMTH.comment=Passt Wärme und Farbe des Block-/Fackellichts an.

value.LIGHTMAP_WARMTH.1=Gemütlich
value.LIGHTMAP_WARMTH.2=Warm
value.LIGHTMAP_WARMTH.3=Intensiv

option.WAVING_LEAVES=Bewegte Blätter
option.WAVING_LEAVES.comment=Aktiviert sanfte Wiegen-Animationen für Baumblätter.

option.WAVING_GRASS=Bewegte Vegetation
option.WAVING_GRASS.comment=Aktiviert Wiegen-Animationen für Gras, Blumen und Feldfrüchte.

option.WIND_SPEED=Windgeschwindigkeit
option.WIND_SPEED.comment=Steuert die Geschwindigkeit von Blättern, Pflanzen und Wasserwellen.

value.WIND_SPEED.1=Sanft
value.WIND_SPEED.2=Brise
value.WIND_SPEED.3=Sturm

option.WATER_WAVES=Wasserwellen
option.WATER_WAVES.comment=Aktiviert geometrische 3D-Wellen auf der Wasseroberfläche.

option.WATER_TRANSPARENCY=Wasserdichte
option.WATER_TRANSPARENCY.comment=Steuert Transparenz und Opazität des Wassers.

value.WATER_TRANSPARENCY.1=Klar
value.WATER_TRANSPARENCY.2=Ausgeglichen
value.WATER_TRANSPARENCY.3=Tief

option.PROCEDURAL_CLOUDS=Volumetrische 3D-Wolken
option.PROCEDURAL_CLOUDS.comment=Aktiviert physisch durchfliegbare 3D-Wolken.

option.CLOUD_HEIGHT=Wolkenhöhe
option.CLOUD_HEIGHT.comment=Legt die physische Höhe (Y-Ebene) der Wolkendecke fest (in Metern).

value.CLOUD_HEIGHT.1=Niedrig (~110m)
value.CLOUD_HEIGHT.2=Standard (~160m)
value.CLOUD_HEIGHT.3=Hoch (~240m)

option.CLOUD_THICKNESS=Wolkendicke
option.CLOUD_THICKNESS.comment=Konfiguriert die vertikale Dicke und das Volumen der Wolken.

value.CLOUD_THICKNESS.1=Dünn (Cirrus)
value.CLOUD_THICKNESS.2=Standard (Cumulus)
value.CLOUD_THICKNESS.3=Dicht (Gewitterwolken)

option.CLOUD_DISTANCE=Cloud Render Distance
option.CLOUD_DISTANCE.comment=Maximum draw distance for volumetric clouds. Quality profiles increase it automatically.
value.CLOUD_DISTANCE.1=Near
value.CLOUD_DISTANCE.2=Standard
value.CLOUD_DISTANCE.3=Far
value.CLOUD_DISTANCE.4=Very Far

