value.NEBULA_BRIGHTNESS.3=Hell

option.STARS_BRIGHTNESS=Sternenhelligkeit
option.STARS_BRIGHTNESS.comment=Steuert die Helligkeit und das Funkeln der Sterne in der Nacht.

