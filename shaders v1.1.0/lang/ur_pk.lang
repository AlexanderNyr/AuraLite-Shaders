# Sun & Moon Lighting (extended)
# ==============================================================================
screen.SUN_MOON=سورج اور چاند
screen.SUN_MOON.comment=سورج اور چاند کی شدت، رنگ کا درجہ حرارت اور ماحولیاتی اثرات کو باریک بینی سے ایڈجسٹ کریں۔

option.SUN_INTENSITY=سورج کی شدت
option.SUN_INTENSITY.comment=براہ راست سورج کی روشنی کی ماسٹر چمک۔ زیادہ = مضبوط دن کا تضاد۔
value.SUN_INTENSITY.1=دھیما
value.SUN_INTENSITY.2=معیاری
value.SUN_INTENSITY.3=بلند
value.SUN_INTENSITY.4=دہکتا ہوا

option.MOON_INTENSITY=چاند کی شدت
option.MOON_INTENSITY.comment=چاندنی کی ماسٹر چمک۔ زیادہ = روشن، زیادہ نظر آنے والی راتیں۔
value.MOON_INTENSITY.1=گھپ اندھیری رات
value.MOON_INTENSITY.2=معیاری
value.MOON_INTENSITY.3=روشن چاند
value.MOON_INTENSITY.4=مکمل رات

option.SUN_TEMPERATURE=سورج کے رنگ کا درجہ حرارت
option.SUN_TEMPERATURE.comment=سورج کے کیلون وکر کو منتقل کرتا ہے۔ حقیقت پسندانہ ٹینر ہیلینڈ بلیک باڈی استعمال کرتا ہے؛ گرم = سنہری؛ ٹھنڈا = غیر جانبدار سفید۔
value.SUN_TEMPERATURE.1=ٹھنڈا / غیر جانبدار
value.SUN_TEMPERATURE.2=حقیقت پسندانہ
value.SUN_TEMPERATURE.3=گرم سنہری

option.MOON_TEMPERATURE=چاند کے رنگ کا درجہ حرارت
option.MOON_TEMPERATURE.comment=چاندنی کا رنگ۔ برفیلا = نیلا سرد؛ چاندی = حقیقت پسندانہ 4100K؛ گرم = ہارویسٹ مون کریم۔
value.MOON_TEMPERATURE.1=برفیلا نیلا
value.MOON_TEMPERATURE.2=چاندی (حقیقت پسندانہ)
value.MOON_TEMPERATURE.3=گرم کریم

option.SUN_HALO=سورج کا ہالہ (مائی سکیٹر)
option.SUN_HALO.comment=سورج کے قریب دیکھتے وقت زمین پر ایک نرم گرم چمک شامل کرتا ہے (مائی فارورڈ سکیٹرنگ)۔

option.SUNRISE_GLOW=بہتر طلوع/غروب آفتاب کی چمک
option.SUNRISE_GLOW.comment=مضبوط گرم بیک سکیٹر کو فعال کرتا ہے جو نیچے سورج سے دور سطحوں کے ارد گرد لپیٹتا ہے۔

