value.NEBULA_BRIGHTNESS.2=معیاری
value.NEBULA_BRIGHTNESS.3=روشن

option.STARS_BRIGHTNESS=ستاروں کی چمک
option.STARS_BRIGHTNESS.comment=رات کو ستاروں کی چمک اور جگمگاتی چمک کو کنٹرول کریں۔

value.STARS_BRIGHTNESS.1=مدھم
value.STARS_BRIGHTNESS.2=معیاری
value.STARS_BRIGHTNESS.3=چمکدار

option.STARS_AMOUNT=ستاروں کی کثافت
option.STARS_AMOUNT.comment=آسمان میں ستاروں کی مجموعی مقدار اور کثافت کو کنٹرول کریں۔

value.STARS_AMOUNT.1=کم
value.STARS_AMOUNT.2=معیاری
value.STARS_AMOUNT.3=گھنا

option.RAINBOW_STRENGTH=قوس قزح کی شدت
option.RAINBOW_STRENGTH.comment=بارش کے بعد قوس قزح کی چمک اور رنگ کی سنترپتی کنفیگر کریں۔

value.RAINBOW_STRENGTH.1=لطیف
value.RAINBOW_STRENGTH.2=متوازن
value.RAINBOW_STRENGTH.3=جاندار

option.COZY_LIGHTS=مشعل کی جھلملاہٹ
option.COZY_LIGHTS.comment=مشعلوں، الاؤ اور لالٹینوں کے لیے گرم، آرام دہ، حقیقی وقت کی جھلملاتی اینیمیشنز فعال کریں۔

option.WET_REFLECTIONS=بارش کی نمی کے انعکاسات
option.WET_REFLECTIONS.comment=جب بارش ہوتی ہے تو زمین، گھاس اور پتھر جیسے ٹھوس بلاکس آسمان کے نیچے گیلے، تاریک اور چمکدار ہو جاتے ہیں۔

option.GROUND_MIST=نچلی زمینی دھند (Y=62-66)
option.GROUND_MIST.comment=صبح/شام کی نرم، سنہری سفید دھند کی چادریں فعال کریں جو طلوع اور غروب کے وقت پانی اور برف پر پھسلتی ہیں۔

option.FOG_DENSITY_LEVEL=دھند کی کثافت
option.FOG_DENSITY_LEVEL.comment=ماحولیاتی افق دھند کی طاقت کو کنٹرول کریں۔

