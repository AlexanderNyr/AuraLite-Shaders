# ==============================================================================
# Quality Profiles
# ==============================================================================
profile.VERY_LOW=بہت کم
profile.VERY_LOW.comment=Fastest possible preset for very weak GPUs. Disables shadows, clouds, water waves, foliage waving, PBR and most extras.
profile.LOW=کم
profile.LOW.comment=Lightweight preset for weak GPUs. Keeps cheap water/foliage motion, disables shadows, clouds and PBR.
profile.MED=درمیانہ
profile.MED.comment=Balanced preset with 1024 shadows, standard clouds, PBR and atmospheric effects.
profile.HIGH=زیادہ
profile.HIGH.comment=High quality preset with 2048 shadows, farther clouds and full PBR, without SSAO.
profile.ULTRA=الٹرا
profile.ULTRA.comment=Ultra quality preset with 4096 shadows, very far clouds and balanced SSAO. POM remains disabled for stability.
profile.EXTREME=انتہائی
profile.EXTREME.comment=Maximum experimental quality. Pushes lighting, clouds, color and deep SSAO. POM remains disabled for stability.
profile.CUSTOM=حسب ضرورت
profile.CUSTOM.comment=صارف کی طرف سے ترمیم شدہ حسب ضرورت ترتیبات۔

screen.TRANSLATION_NOTICE=⚠ ترجموں میں غلطیاں ہو سکتی ہیں
screen.TRANSLATION_NOTICE.comment=کچھ لوکلائزیشن سٹرنگز غلط ہو سکتی ہیں۔ اگر کچھ عجیب لگے تو انگریزی اصل سے موازنہ کریں۔

# Screens
screen.LIGHTING=روشنی کی ترتیبات
screen.LIGHTING.comment=سائے، روشنی کے رنگ اور چمک کنفیگر کریں۔

screen.FOLIAGE=پودوں کی ترتیبات
screen.FOLIAGE.comment=گھاس اور پتوں کے لیے لہراتی اینیمیشنز کنفیگر کریں۔

screen.WATER=پانی کی ترتیبات
screen.WATER.comment=لہریں، شفافیت اور پانی کا انداز کنفیگر کریں۔

screen.CLOUDS_MENU=آسمان اور بادل
screen.CLOUDS_MENU.comment=3D بادلوں اور آسمانی اثرات کی جسمانی اونچائی، موٹائی اور انداز کنفیگر کریں۔

screen.POST_PROCESS=پوسٹ پروسیسنگ اور دھند
screen.POST_PROCESS.comment=ایکسپوژر، دھند اور سینمائی اثرات کنفیگر کریں۔

# Options
option.SHADOWS=متحرک سائے
option.SHADOWS.comment=سورج اور چاند سے نرم متحرک سائے فعال یا غیر فعال کریں۔

option.SHADOW_RES=سائے کی ریزولوشن
option.SHADOW_RES.comment=شیڈو میپ کوالٹی تبدیل کریں۔ زیادہ اقدار کارکردگی کو کم کر سکتی ہیں۔

option.PBR_LIGHTING=PBR روشنی (LabPBR)
option.PBR_LIGHTING.comment=دھاتوں، کھردرے پن اور 3D نارمل نقشوں کے لیے فزیکل بیسڈ رینڈرنگ فعال کریں (PBR ریسورس پیک درکار ہے)۔

option.PBR_POM=3D بلاک ریلیف (POM)
option.PBR_POM.comment=3D بلاک ساخت کے لیے فزیکل بیسڈ پیرالیکس اوکلوژن میپنگ فعال کریں۔ غیر مطابقت پذیر ریسورس پیکس پر غیر فعال کرنے کی سفارش کی جاتی ہے۔

option.PBR_STRENGTH=PBR شدت
option.PBR_STRENGTH.comment=PBR دھاتی سطحوں کی عکاسی اور چمک کو کنٹرول کریں۔

value.PBR_STRENGTH.1=لطیف
value.PBR_STRENGTH.2=معیاری
value.PBR_STRENGTH.3=آئینہ

option.SSAO=SSAO / SAO اوکلوژن
option.SSAO.comment=Extreme profile: screen-space ambient occlusion for contact shadows in corners, under blocks, and around geometry intersections.
option.SSAO_STRENGTH=SSAO طاقت
option.SSAO_STRENGTH.comment=اسکرین اسپیس ایمبیئنٹ اوکلوژن کی گہرائی کو کنٹرول کرتا ہے۔ صرف اس وقت فعال جب SSAO فعال ہو۔
value.SSAO_STRENGTH.1=لطیف
value.SSAO_STRENGTH.2=متوازن
value.SSAO_STRENGTH.3=گہرا

option.LIGHTMAP_WARMTH=مشعل کی گرمی
option.LIGHTMAP_WARMTH.comment=بلاک/مشعل کی روشنی کی گرمی اور رنگ ایڈجسٹ کریں۔

value.LIGHTMAP_WARMTH.1=آرام دہ
value.LIGHTMAP_WARMTH.2=گرم
value.LIGHTMAP_WARMTH.3=شدید

option.WAVING_LEAVES=لہراتے پتے
option.WAVING_LEAVES.comment=درخت کے پتوں کے لیے نرم لہراتی اینیمیشنز فعال کریں۔

option.WAVING_GRASS=لہراتی نباتات
option.WAVING_GRASS.comment=گھاس، پھولوں اور فصلوں کے لیے لہراتی اینیمیشنز فعال کریں۔

option.WIND_SPEED=ہوا کی رفتار
option.WIND_SPEED.comment=پتوں، پودوں اور پانی کی لہروں کی لہرانے کی رفتار کو کنٹرول کریں۔

value.WIND_SPEED.1=Gentle
value.WIND_SPEED.2=Breeze
value.WIND_SPEED.3=Gale

option.WATER_WAVES=پانی کی لہریں
option.WATER_WAVES.comment=Enable 3D geometric waves on the water surface.

option.WATER_TRANSPARENCY=پانی کی کثافت
option.WATER_TRANSPARENCY.comment=Control the transparency and opacity of the water.

value.WATER_TRANSPARENCY.1=صاف
value.WATER_TRANSPARENCY.2=متوازن
value.WATER_TRANSPARENCY.3=گہرا

option.PROCEDURAL_CLOUDS=والیومیٹرک 3D بادل
option.PROCEDURAL_CLOUDS.comment=جسمانی طور پر اڑنے کے قابل 3D بادل فعال کریں جن تک پہنچا اور اڑان بھری جا سکتی ہے۔

option.CLOUD_HEIGHT=بادل کی اونچائی
option.CLOUD_HEIGHT.comment=دنیا میں بادل کی تہہ کی جسمانی اونچائی (Y-سطح) سیٹ کریں (میٹر میں)۔

value.CLOUD_HEIGHT.1=کم (~110م)
value.CLOUD_HEIGHT.2=معیاری (~160م)
value.CLOUD_HEIGHT.3=بلند (~240م)

option.CLOUD_THICKNESS=بادل کی موٹائی
option.CLOUD_THICKNESS.comment=بادلوں کی عمودی موٹائی اور حجم کنفیگر کریں۔

value.CLOUD_THICKNESS.1=پتلا (Cirrus)
value.CLOUD_THICKNESS.2=معیاری (Cumulus)
value.CLOUD_THICKNESS.3=گھنا (طوفانی)

option.CLOUD_DISTANCE=کلاؤڈ رینڈر فاصلہ
option.CLOUD_DISTANCE.comment=والیومیٹرک بادلوں کے لیے زیادہ سے زیادہ ڈرا فاصلہ۔ کوالٹی پروفائلز خودکار طور پر اسے بڑھاتے ہیں۔
value.CLOUD_DISTANCE.1=قریب
value.CLOUD_DISTANCE.2=معیاری
value.CLOUD_DISTANCE.3=دور
value.CLOUD_DISTANCE.4=بہت دور

option.CLOUD_SHADOWS=بادل کے سائے
option.CLOUD_SHADOWS.comment=زمین پر والیومیٹرک بادل کثافت سے شفاف طریقہ کار کے سائے شامل کرتا ہے۔ کوالٹی پروفائلز کے ذریعے متوازن۔
option.CLOUD_SHADOW_STRENGTH=بادل کے سائے کی طاقت
option.CLOUD_SHADOW_STRENGTH.comment=کنٹرول کرتا ہے کہ شفاف بادل کے سائے کتنے نظر آنے والے اور ڈرامائی ہیں۔
value.CLOUD_SHADOW_STRENGTH.1=نرم
value.CLOUD_SHADOW_STRENGTH.2=متوازن
value.CLOUD_SHADOW_STRENGTH.3=ڈرامائی

option.GODRAYS=سورج کی کرنیں (Godrays)
option.GODRAYS.comment=Adds physically-inspired volumetric single-scattering sun shafts with Beer-Lambert extinction, Mie phase and shadow-map occlusion.
option.GODRAYS_QUALITY=Godrays معیار
option.GODRAYS_QUALITY.comment=Controls the sample count and integration distance of physically-based volumetric godrays.
value.GODRAYS_QUALITY.1=تیز
value.GODRAYS_QUALITY.2=متوازن
value.GODRAYS_QUALITY.3=بلند

option.AURORA_MODE=قطبی روشنی
option.AURORA_MODE.comment=رات کے آسمان پر حقیقت پسندانہ بہتی ہوئی قطبی روشنی کی نمائش کو کنٹرول کریں۔

value.AURORA_MODE.0=غیر فعال
value.AURORA_MODE.1=صرف ٹھنڈے بایوم میں
value.AURORA_MODE.2=ہمیشہ فعال

option.AURORA_SPEED=قطبی روشنی کی رفتار
option.AURORA_SPEED.comment=شمالی روشنیوں کی لہرانے اور بہنے کی رفتار کو کنٹرول کریں۔

value.AURORA_SPEED.1=سست
value.AURORA_SPEED.2=معیاری
value.AURORA_SPEED.3=تیز

option.AURORA_STRENGTH=قطبی روشنی کی چمک
option.AURORA_STRENGTH.comment=شمالی روشنیوں کی مجموعی چمک کو کنٹرول کریں۔

value.AURORA_STRENGTH.1=نرم
value.AURORA_STRENGTH.2=معیاری
value.AURORA_STRENGTH.3=چمکتا ہوا

option.NEBULA_BRIGHTNESS=ملکی وے کی چمک
option.NEBULA_BRIGHTNESS.comment=رات کو ترچھی بھوری کہکشاں نیبولا کی چمک کو ایڈجسٹ کریں۔

