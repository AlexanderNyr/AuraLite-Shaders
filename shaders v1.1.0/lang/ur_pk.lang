value.EXPOSURE.2=متوازن
value.EXPOSURE.3=زندہ دل

option.COLOR_SATURATION=رنگ کی زندگی
option.COLOR_SATURATION.comment=اسکرین کے رنگوں کی نان لینیئر سنترپتی کو کنٹرول کریں۔ پودوں کو زمردی اور آسمانوں کو شاداب بناتا ہے۔

value.COLOR_SATURATION.1=دھیما
value.COLOR_SATURATION.2=متوازن
value.COLOR_SATURATION.3=رنگین
value.COLOR_SATURATION.4=جاندار

option.CONTRAST=تصویر کا تضاد
option.CONTRAST.comment=ٹون میپنگ اور تضاد وکر انداز منتخب کریں۔

value.CONTRAST.1=نرم
value.CONTRAST.2=فلمی (ACES)
value.CONTRAST.3=شدید (اعلی تضاد)

option.TAA=ٹیمپورل اینٹی الائیزنگ (TAA)
option.TAA.comment=موشن ری پروجیکشن اور نیبرہڈ کلپنگ کے ساتھ ٹیمپورل ریزولو۔ اعلی پری سیٹس پر جھلملاہٹ اور دانتے دار کناروں کو کم کرتا ہے۔
option.TAA_STRENGTH=TAA طاقت
option.TAA_STRENGTH.comment=تاریخ ملاپ کو کنٹرول کرتا ہے۔ زیادہ زیادہ مستحکم ہے لیکن حرکت کے دوران نرم ہو سکتا ہے۔
value.TAA_STRENGTH.1=ہلکا
value.TAA_STRENGTH.2=متوازن
value.TAA_STRENGTH.3=مستحکم

option.VIGNETTE=وگنیٹ اثر
option.VIGNETTE.comment=بہتر فوکس کے لیے اسکرین کے کناروں پر لطیف تاریکی فعال کریں۔

option.WATER_RIFFLES=پانی کی لہر کی طاقت
option.WATER_RIFFLES.comment=Adjust the waviness and intensity of the fine normal map ripples on the water.

value.WATER_RIFFLES.1=پرسکون
value.WATER_RIFFLES.2=معیاری
value.WATER_RIFFLES.3=موجزن

option.WATER_SPECULAR_STRENGTH=پانی کی عکاسی چمک
option.WATER_SPECULAR_STRENGTH.comment=Adjust the brightness of sun/moon reflections on the water ripples.

value.WATER_SPECULAR_STRENGTH.1=نرم
value.WATER_SPECULAR_STRENGTH.2=معیاری
value.WATER_SPECULAR_STRENGTH.3=چمکتا ہوا

option.SHADOW_SOFTNESS=سائے کی نرمی
option.SHADOW_SOFTNESS.comment=کنٹرول کرتا ہے کہ سائے کے کنارے کتنے نرم اور پھیلے ہوئے نظر آتے ہیں۔ ہموار نیم سائے کے لیے گھمائے گئے پوئسن ڈسک فلٹرنگ استعمال کرتا ہے۔

value.SHADOW_SOFTNESS.1=تیز
value.SHADOW_SOFTNESS.2=نرم
value.SHADOW_SOFTNESS.3=انتہائی نرم

