# ==============================================================================
option.SPATIAL_AA_MODE=Киңлек тигезләве
option.SPATIAL_AA_MODE.comment=Эшкәртүдән соң тигезләү ысулын сайлагыз. FXAA тиз һәм арзан. SMAA геометрия кырыйларында яхшырак сыйфат өчен тирәнлек буферын куллана. TAA белән берләштерелә ала.
value.SPATIAL_AA_MODE.0=Сүндерелгән
value.SPATIAL_AA_MODE.1=FXAA (Тиз)
value.SPATIAL_AA_MODE.2=SMAA (Сыйфат)

