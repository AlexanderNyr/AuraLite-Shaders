option.STARS_BRIGHTNESS.comment=Төнлә йолдызларның яктылыгын һәм җемелдәүче балкуын контрольдә тотыгыз.

value.STARS_BRIGHTNESS.1=Сүрән
value.STARS_BRIGHTNESS.2=Стандарт
value.STARS_BRIGHTNESS.3=Гаҗәеп

option.STARS_AMOUNT=Йолдыз тыгызлыгы
option.STARS_AMOUNT.comment=Күктәге йолдызларның гомуми санын һәм тыгызлыгын контрольдә тотыгыз.

value.STARS_AMOUNT.1=Аз
value.STARS_AMOUNT.2=Стандарт
value.STARS_AMOUNT.3=Куе

