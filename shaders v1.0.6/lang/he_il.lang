value.PBR_STRENGTH.2=סטנדרטית
value.PBR_STRENGTH.3=מראה
option.LIGHTMAP_WARMTH=חום הלפיד
option.LIGHTMAP_WARMTH.comment=מתאים את החום והצבע של אור קוביות/לפידים.
value.LIGHTMAP_WARMTH.1=חמים ונעים
value.LIGHTMAP_WARMTH.2=חמים
value.LIGHTMAP_WARMTH.3=עז
option.WAVING_LEAVES=עלים מתנדנדים
option.WAVING_LEAVES.comment=מפעיל אנימציות נדנוד עדינות לעלי עצים.
option.WAVING_GRASS=צמחייה מתנדנדת
option.WAVING_GRASS.comment=מפעיל אנימציות נדנוד לדשא, פרחים וגידולים.
option.WIND_SPEED=מהירות רוח
option.WIND_SPEED.comment=שולט במהירות הנדנוד של עלים, צמחים וגלי מים.
value.WIND_SPEED.1=עדין
value.WIND_SPEED.2=משב
value.WIND_SPEED.3=סערה
option.WATER_WAVES=גלי מים
option.WATER_WAVES.comment=מפעיל גלים גיאומטריים תלת-ממדיים על פני המים.
option.WATER_TRANSPARENCY=צפיפות מים
option.WATER_TRANSPARENCY.comment=שולט בשקיפות ובאטימות של המים.
value.WATER_TRANSPARENCY.1=צלולים
value.WATER_TRANSPARENCY.2=מאוזנים
value.WATER_TRANSPARENCY.3=עמוקים
option.PROCEDURAL_CLOUDS=עננים נפחיים תלת-ממדיים
option.PROCEDURAL_CLOUDS.comment=מפעיל עננים תלת-ממדיים פיזיים שניתן לעוף דרכם.
option.CLOUD_HEIGHT=גובה עננים
option.CLOUD_HEIGHT.comment=מגדיר את הגובה הפיזי (רמת Y) של שכבת העננים בעולם (במטרים).
