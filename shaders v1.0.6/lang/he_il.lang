# ==============================================================================
# Quality Profiles
# ==============================================================================
profile.VERY_LOW=Very Low
profile.VERY_LOW.comment=Fastest possible preset for very weak GPUs. Disables heavy effects.
profile.LOW=נמוך
profile.MED=בינוני
profile.HIGH=גבוה
profile.ULTRA=אולטרה
profile.EXTREME=Extreme
profile.EXTREME.comment=איכות ניסיונית מקסימלית. מוסיף חסימה היקפית במגע SSAO/SAO. POM נשאר מושבת ליציבות.
profile.CUSTOM=מותאם אישית
profile.CUSTOM.comment=הגדרות מותאמות אישית.
profile.HIGH.comment=איכות גבוהה עם צללים רחוקים יותר ותאורה בהירה יותר.
profile.LOW.comment=ההגדרה המהירה ביותר ל-GPUs חלשים. מבטל אפקטים כבדים.
profile.MED.comment=הגדרה מאוזנת עם צללים, עננים, PBR ואפקטים אטמוספריים.
profile.ULTRA.comment=איכות חזותית מקסימלית. POM נשאר מושבת ליציבות.

screen.TRANSLATION_NOTICE=⚠ התרגומים עשויים להכיל שגיאות
screen.TRANSLATION_NOTICE.comment=ייתכן שחלק ממחרוזות התרגום אינן מדויקות. אם משהו נראה מוזר, השווה למקור האנגלי.

# Screens
screen.LIGHTING=הגדרות תאורה
screen.LIGHTING.comment=הגדירו צללים, צבעי אור ובהירות.
screen.FOLIAGE=הגדרות צמחייה
screen.FOLIAGE.comment=הגדירו אנימציות נדנוד לדשא ולעלים.
screen.WATER=הגדרות מים
screen.WATER.comment=הגדירו גלים, שקיפות וסגנון מים.
screen.CLOUDS_MENU=שמיים ועננים
screen.CLOUDS_MENU.comment=הגדירו גובה פיזי, עובי וסגנון של עננים תלת-ממדיים ואפקטים של שמיים.
screen.POST_PROCESS=עיבוד אחר וערפל
screen.POST_PROCESS.comment=הגדירו חשיפה, ערפל ואפקטים קולנועיים.

# Options
option.SHADOWS=צללים דינמיים
option.SHADOWS.comment=מפעיל או משבית צללים דינמיים רכים מהשמש והירח.
option.SHADOW_RES=רזולוציית צללים
option.SHADOW_RES.comment=משנה את איכות מפת הצללים. ערכים גבוהים יותר מורידים את הביצועים.
option.PBR_LIGHTING=תאורת PBR (LabPBR)
option.PBR_LIGHTING.comment=מפעיל רינדור מבוסס פיזיקה למתכות, חספוס ומפות נורמלים תלת-ממדיות (נדרשת חבילת משאבים PBR).
option.PBR_POM=תבליט תלת-ממדי לקוביות (POM)
option.PBR_POM.comment=מפעיל Parallax Occlusion Mapping לטקסטורות קוביות תלת-ממדיות אמיתיות. מומלץ להשבית בחבילות לא תואמות.
option.PBR_STRENGTH=עוצמת PBR
option.PBR_STRENGTH.comment=שולט בהחזריות ובברק של משטחי PBR מתכתיים.
